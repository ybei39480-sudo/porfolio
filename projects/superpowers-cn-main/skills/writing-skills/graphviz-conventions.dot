digraph STYLE_GUIDE {
    // 我们流程 DSL 的样式指南，用 DSL 本身编写

    // 节点类型示例及其形状
    subgraph cluster_node_types {
        label="节点类型和形状";

        // 问题用菱形
        "这是问题吗？" [shape=diamond];

        // 行动用方框（默认）
        "执行行动" [shape=box];

        // 命令用纯文本
        "git commit -m 'msg'" [shape=plaintext];

        // 状态用椭圆
        "当前状态" [shape=ellipse];

        // 警告用八边形
        "停止：关键警告" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];

        // 入口/出口用双圆
        "流程开始" [shape=doublecircle];
        "流程完成" [shape=doublecircle];

        // 每种类型示例
        "测试通过了吗？" [shape=diamond];
        "先写测试" [shape=box];
        "npm test" [shape=plaintext];
        "我卡住了" [shape=ellipse];
        "绝不使用 git add -A" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];
    }

    // 边标签约定
    subgraph cluster_edge_types {
        label="边标签约定";

        "二元决策？" [shape=diamond];
        "是路径" [shape=box];
        "否路径" [shape=box];

        "二元决策？" -> "是路径" [label="yes"];
        "二元决策？" -> "否路径" [label="no"];

        "多选？" [shape=diamond];
        "选项 A" [shape=box];
        "选项 B" [shape=box];
        "选项 C" [shape=box];

        "多选？" -> "选项 A" [label="条件 A"];
        "多选？" -> "选项 B" [label="条件 B"];
        "多选？" -> "选项 C" [label="其他"];

        "流程 A 完成" [shape=doublecircle];
        "流程 B 开始" [shape=doublecircle];

        "流程 A 完成" -> "流程 B 开始" [label="触发", style=dotted];
    }

    // 命名模式
    subgraph cluster_naming_patterns {
        label="命名模式";

        // 问题以问号结尾
        "我应该做 X 吗？";
        "这可以是 Y 吗？";
        "Z 是真的吗？";
        "我做了 W 吗？";

        // 行动以动词开头
        "写测试";
        "搜索模式";
        "提交更改";
        "寻求帮助";

        // 命令用字面量
        "grep -r 'pattern' .";
        "git status";
        "npm run build";

        // 状态描述情况
        "测试失败";
        "构建完成";
        "错误卡住";
    }

    // 流程结构模板
    subgraph cluster_structure {
        label="流程结构模板";

        "触发：某事发生" [shape=ellipse];
        "初始检查？" [shape=diamond];
        "主要行动" [shape=box];
        "git status" [shape=plaintext];
        "另一个检查？" [shape=diamond];
        "替代行动" [shape=box];
        "停止：不要这样做" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];
        "流程完成" [shape=doublecircle];

        "触发：某事发生" -> "初始检查？";
        "初始检查？" -> "主要行动" [label="是"];
        "初始检查？" -> "替代行动" [label="否"];
        "主要行动" -> "git status";
        "git status" -> "另一个检查？";
        "另一个检查？" -> "流程完成" [label="正常"];
        "另一个检查？" -> "停止：不要这样做" [label="问题"];
        "替代行动" -> "流程完成";
    }

    // 何时使用哪种形状
    subgraph cluster_shape_rules {
        label="何时使用哪种形状";

        "选择形状" [shape=ellipse];

        "这是决策？" [shape=diamond];
        "用菱形" [shape=diamond, style=filled, fillcolor=lightblue];

        "这是命令？" [shape=diamond];
        "用纯文本" [shape=plaintext, style=filled, fillcolor=lightgray];

        "这是警告？" [shape=diamond];
        "用八边形" [shape=octagon, style=filled, fillcolor=pink];

        "这是入口/出口？" [shape=diamond];
        "用双圆" [shape=doublecircle, style=filled, fillcolor=lightgreen];

        "这是状态？" [shape=diamond];
        "用椭圆" [shape=ellipse, style=filled, fillcolor=lightyellow];

        "默认：用方框" [shape=box, style=filled, fillcolor=lightcyan];

        "选择形状" -> "这是决策？";
        "这是决策？" -> "用菱形" [label="是"];
        "这是决策？" -> "这是命令？" [label="否"];
        "这是命令？" -> "用纯文本" [label="是"];
        "这是命令？" -> "这是警告？" [label="否"];
        "这是警告？" -> "用八边形" [label="是"];
        "这是警告？" -> "这是入口/出口？" [label="否"];
        "这是入口/出口？" -> "用双圆" [label="是"];
        "这是入口/出口？" -> "这是状态？" [label="否"];
        "这是状态？" -> "用椭圆" [label="是"];
        "这是状态？" -> "默认：用方框" [label="否"];
    }

    // 好与坏示例
    subgraph cluster_examples {
        label="好与坏示例";

        // 好：具体且形状正确
        "测试失败" [shape=ellipse];
        "阅读错误消息" [shape=box];
        "能复现吗？" [shape=diamond];
        "git diff HEAD~1" [shape=plaintext];
        "绝不忽略错误" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];

        "测试失败" -> "阅读错误消息";
        "阅读错误消息" -> "能复现吗？";
        "能复现吗？" -> "git diff HEAD~1" [label="是"];

        // 坏：模糊且形状错误
        bad_1 [label="某处出错", shape=box];  // 应该是椭圆（状态）
        bad_2 [label="修复它", shape=box];  // 太模糊
        bad_3 [label="检查", shape=box];  // 应该是菱形
        bad_4 [label="运行命令", shape=box];  // 应该是纯文本加实际命令

        bad_1 -> bad_2;
        bad_2 -> bad_3;
        bad_3 -> bad_4;
    }
}
